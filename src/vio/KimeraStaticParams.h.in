#pragma once

// AUTO-GENERATED at CMake configure time from
//   share/posest/kimera/{Frontend,Backend,Imu,Pipeline,Lcd,Display}Params.yaml.
// Do NOT edit this file directly — edit the source YAMLs and
// re-run CMake. The contents are embedded as raw string literals
// using a long delimiter so any future YAML never accidentally
// contains the closing token.

#include <string_view>

namespace posest::vio::static_params {

inline constexpr std::string_view kFrontendParamsYaml = R"posest_yaml(@POSEST_KIMERA_FRONTEND_YAML@)posest_yaml";

inline constexpr std::string_view kBackendParamsYaml = R"posest_yaml(@POSEST_KIMERA_BACKEND_YAML@)posest_yaml";

// IMU template. The runtime writer appends an `IMUtoBodyT_BS:` block to
// this template, populated from FusionConfig::imu_extrinsic_body_to_imu
// (inverted to satisfy Kimera's IMU→body convention).
inline constexpr std::string_view kImuParamsTemplateYaml = R"posest_yaml(@POSEST_KIMERA_IMU_TEMPLATE_YAML@)posest_yaml";

// Pipeline / LCD / Display YAMLs. Required by VioParams::parseYAML
// (see Kimera-VIO/src/pipeline/Pipeline-definitions.cpp:109-185 — the
// parser unconditionally reads all four of these even though our
// MonoImuPipeline doesn't use the LCD or display modules at runtime).
inline constexpr std::string_view kPipelineParamsYaml = R"posest_yaml(@POSEST_KIMERA_PIPELINE_YAML@)posest_yaml";

inline constexpr std::string_view kLcdParamsYaml = R"posest_yaml(@POSEST_KIMERA_LCD_YAML@)posest_yaml";

inline constexpr std::string_view kDisplayParamsYaml = R"posest_yaml(@POSEST_KIMERA_DISPLAY_YAML@)posest_yaml";

}  // namespace posest::vio::static_params
